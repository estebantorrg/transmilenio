{
  "name": "transmilenio-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "sync": "tsx src/sync.ts",
    "prune": "tsx src/prune_catalog.ts",
    "relay:co": "tsx src/colombia_live_relay.ts",
    "build": "tsc && node --input-type=module -e \"import fs from 'fs'; fs.cpSync('src/data', 'dist/data', { recursive: true });\"",
    "start": "node dist/index.js",
    "sync:recarga": "tsx src/sync_recarga.ts",
    "sync:demand": "tsx src/sync_demand.ts",
    "sync:transmibici": "tsx src/sync_transmibici.ts"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
