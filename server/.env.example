PORT=3001
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: external live-bus proxy URL. Must egress from Colombia to work.
# TRANSMILENIO_LIVE_PROXY_URL=https://your-proxy.example.com
# TRANSMILENIO_GAS_PROXY_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec

# Optional: Colombia IP placed in forwarding headers for the live-bus API.
# TRANSMILENIO_COLOMBIA_CLIENT_IP=181.50.0.1
