PORT=3001
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Live tracking must originate from Colombia. Run `npm --prefix server run relay:co`
# on a machine/network in Colombia (e.g. an Oracle Cloud Always Free VM in the
# Bogotá region), expose it over HTTPS (Tailscale Funnel / Cloudflare Tunnel).
#
# Browser-direct mode (preferred): set RELAY_CLIENT_ORIGINS to your web app's
# origin(s) so the relay serves CORS and the browser can call it straight. No
# secret needed for allow-listed browser origins.
# RELAY_CLIENT_ORIGINS=https://transmilenio.onrender.com
#
# Server-relay mode (fallback): point the main server at the relay instead.
# TRANSMILENIO_COLOMBIA_RELAY_URL=https://your-colombia-relay.example.com
# TRANSMILENIO_COLOMBIA_RELAY_SECRET=change-me

# Optional, not lifetime-reliable: try public Colombian proxies only if relay is down.
# TRANSMILENIO_ALLOW_PUBLIC_CO_PROXY=0
