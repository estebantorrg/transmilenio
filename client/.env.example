VITE_API_BASE_URL=http://localhost:3001/api

# Optional: Colombia relay the browser calls DIRECTLY for live tracking (PC +
# mobile, no extension). Must be HTTPS (mixed-content rule) and egress from a
# Colombian IP. When set, the client uses: Live Bridge extension → this relay →
# main server /api/buses. Leave blank to use only the main server relay.
# VITE_LIVE_RELAY_URL=https://your-relay.ts.net
